    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "franc-min": "^6.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "multer": "^1.4.5-lts.1",

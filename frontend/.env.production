# This file is committed to git — DO NOT put real secrets here.
# Set VITE_API_URL in Vercel Frontend → Settings → Environment Variables
# so Vercel uses the correct value at build time.

# Replace with your Vercel backend URL (e.g. https://leader-backend.vercel.app)
VITE_API_URL=https://leader-backend.vercel.app/api
VITE_CRAWLER_API_URL=https://leader-backend.vercel.app/api/crawler
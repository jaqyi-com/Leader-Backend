# ============================================================
# LEADER AI — ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# ============================================================

# ── OpenAI (LLM + Embeddings) ────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o                  # Optional: defaults to gpt-4o

# ── Apollo.io (Lead Enrichment) ──────────────────────────────
APOLLO_API_KEY=your-apollo-api-key

# ── SMTP (Email Outreach) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password          # Gmail: use App Password, not account password
SMTP_FROM_NAME=Leader
SMTP_FROM_EMAIL=your-email@gmail.com

# ── MongoDB Atlas ────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Leader

# ── Pipeline Settings ────────────────────────────────────────
PORT=3001
MAX_COMPANIES_PER_RUN=100
MAX_CONTACTS_PER_COMPANY=3
OUTREACH_DAILY_EMAIL_LIMIT=200
OUTREACH_DELAY_BETWEEN_EMAILS_MS=3000
FORCE_SEND_MOCK_EMAILS=false
ENABLE_AB_TESTING=false

# ── Scraping Settings ─────────────────────────────────────────
SCRAPING_DELAY_MS=2000
MAX_CONCURRENT_SCRAPERS=3
USE_HEADLESS_BROWSER=true

# ── Scoring Thresholds ───────────────────────────────────────
HIGH_PRIORITY_SCORE=75
MEDIUM_PRIORITY_SCORE=50

# ── Google Places API ────────────────────────────────────────
GOOGLE_API_KEY=AIzaSy...

# ── Vite Frontend (local dev only) ───────────────────────────
VITE_API_URL=http://localhost:3001/api
VITE_CRAWLER_API_URL=http://localhost:3001/api/crawler

# ── Redis (Upstash — serverless Redis) ───────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ── Frontend URL (email links + OAuth redirect) ───────────────
# Local dev:
FRONTEND_URL=http://localhost:5174
# Production: set this to your Vercel frontend URL, e.g.:
# FRONTEND_URL=https://leader-frontend.vercel.app

# ── CORS ─────────────────────────────────────────────────────
# Optional: restrict CORS to a specific origin in production
# CORS_ORIGIN=https://leader-frontend.vercel.app

# ── Unified.to (Social Media Integration) ────────────────────
UNIFIED_API_KEY=your-unified-api-key
UNIFIED_WORKSPACE_ID=your-workspace-id
UNIFIED_WORKSPACE_SECRET=your-workspace-secret
UNIFIED_BASE_URL=https://api.unified.to
